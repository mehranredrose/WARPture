{
  "name": "warpture-gui",
  "version": "1.0.0",
  "description": "WARPture – Cloudflare WARP GUI Manager with App Split Tunneling",
  "main": "electron/main.js",
  "homepage": "https://github.com/mehranredrose/WARPture",
  "author": {
    "name": "mehranredrose",
    "email": "77771629+mehranredrose@users.noreply.github.com"
  },
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:react\" \"wait-on http://localhost:3000 && npm run dev:electron\"",
    "dev:react": "react-scripts start",
    "dev:electron": "NODE_ENV=development electron .",
    "build": "react-scripts build",
    "build:electron": "npm run build && electron-builder",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "test": "react-scripts test",
    "lint": "eslint src electron --ext .ts,.tsx,.js",
    "lint:fix": "eslint src electron --ext .ts,.tsx,.js --fix",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "axios": "^1.6.0",
    "react-icons": "^4.12.0",
    "clsx": "^2.0.0",
    "zustand": "^4.4.7",
    "framer-motion": "^10.16.0",
    "react-virtualized-auto-sizer": "^1.0.20",
    "react-window": "^1.8.10",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.10",
    "@types/react-window": "^1.8.8",
    "typescript": "^5.3.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "concurrently": "^8.2.0",
    "wait-on": "^7.2.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0"
  },
  "build": {
    "appId": "com.mehranredrose.warpture",
    "productName": "WARPture",
    "copyright": "Copyright © 2025 mehranredrose",
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "electron/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "assets/icon.icns",
      "target": ["dmg", "zip"],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "packaging/macos/entitlements.plist",
      "entitlementsInherit": "packaging/macos/entitlements.plist"
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": ["deb", "rpm", "AppImage"],
      "category": "Utility",
      "desktop": {
        "Name": "WARPture",
        "Comment": "Cloudflare WARP GUI Manager",
        "StartupWMClass": "WARPture"
      }
    },
    "dmg": {
      "title": "WARPture ${version}",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  },
  "browserslist": {
    "production": [">0.2%", "not dead", "not op_mini all"],
    "development": ["last 1 chrome version", "last 1 firefox version", "last 1 safari version"]
  }
}
