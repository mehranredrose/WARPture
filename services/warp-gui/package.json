{
  "name": "warpture-gui",
  "version": "1.0.1",
  "description": "WARPture – Cloudflare WARP GUI Manager with App Split Tunneling",
  "main": "electron/main.js",
  "homepage": "https://github.com/mehranredrose/WARPture",
  "author": {
    "name": "mehranredrose",
    "email": "77771629+mehranredrose@users.noreply.github.com"
  },
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:react\" \"wait-on http://localhost:3000 && npm run dev:electron\"",
    "dev:react": "vite",
    "dev:electron": "NODE_ENV=development electron .",
    "build": "vite build",
    "build:electron": "npm run build && electron-builder",
    "build:mac": "./node_modules/.bin/vite build && ./node_modules/.bin/electron-builder --mac",
    "build:linux": "./node_modules/.bin/vite build && ./node_modules/.bin/electron-builder --linux",
    "test": "react-scripts test",
    "lint": "eslint src electron --ext .ts,.tsx,.js",
    "lint:fix": "eslint src electron --ext .ts,.tsx,.js --fix",
    "postinstall": "electron-builder install-app-deps",
    "build:win": "node_modules\\.bin\\vite build && node_modules\\.bin\\electron-builder --win"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "clsx": "^2.0.0",
    "framer-motion": "^10.16.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^4.12.0",
    "react-scripts": "5.0.1",
    "react-virtualized-auto-sizer": "^1.0.20",
    "react-window": "^1.8.10",
    "ws": "^8.16.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-window": "^1.8.8",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "eslint": "^8.55.0",
    "typescript": "^5.3.0",
    "vite": "^8.0.16",
    "wait-on": "^7.2.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "type": "commonjs"
}
